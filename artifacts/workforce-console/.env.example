# Workforce Console — Environment Configuration

# API base URL
# Option A (recommended for development): leave empty — uses the built-in Vite proxy.
#   The proxy forwards /api/v1/* → https://hn3t.pythonanywhere.com with no CORS issues.
# Option B (direct, needs CORS on the server): set to the API origin.
#   VITE_API_BASE_URL=https://hn3t.pythonanywhere.com
VITE_API_BASE_URL=

# Demo mode: set to "true" to use mock/demo data without a live API.
# Set to "false" (or remove) for live API mode.
VITE_DEMO_MODE=false

# Vite dev/preview server port.
# Required for `pnpm dev` and `pnpm serve` (preview). Not required for `pnpm build`.
# Defaults to 5000 if not set during dev/preview.
PORT=5000

# Base path for the SPA (used by Vite as `base`).
# Defaults to "/" if not set. Override only when serving from a sub-path.
# BASE_PATH=/

# Optional: override the Vite API proxy target (dev only).
# Defaults to https://hn3t.pythonanywhere.com.
# VITE_API_PROXY_TARGET=http://localhost:8080
