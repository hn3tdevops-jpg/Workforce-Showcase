# Workforce Console — Environment Configuration

# API base URL (change for staging/production)
VITE_API_BASE_URL=https://hn3t.pythonanywhere.com

# Demo mode: set to "true" to use mock data instead of live API calls.
# Mock data uses the same shapes as the live API so swapping is transparent.
# Set to "false" (or remove) for live API mode.
VITE_DEMO_MODE=false
